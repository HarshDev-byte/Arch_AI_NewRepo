## ArchAI backend example environment variables
## Copy to .env and fill with real secrets. DO NOT commit real secrets.

# Database / Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=service_role_key_here
SUPABASE_JWT_SECRET=change-this-jwt-secret

# Vault secret used to encrypt API keys stored in DB
# Replace with a long random string before running in production
VAULT_SECRET=pick-any-random-long-string-change-this-now

# -------------------- Gemini (3 free keys) --------------------
# Create up to 3 Google API keys (aistudio.google.com) and paste them below.
# No billing; use separate Gmail accounts for each key to get free quotas.
GEMINI_KEY_A=AIzaSy...   # Google account 1
GEMINI_KEY_B=AIzaSy...   # Google account 2 (optional)
GEMINI_KEY_C=AIzaSy...   # Google account 3 (optional)
GEMINI_MODEL=gemini-1.5-flash

# Optional fallback provider keys (use your own free/dev keys)
# These are used only if a user hasn't provisioned a key via the UI.
GROQ_API_KEY=gsk_your_groq_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Maps / frontend
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Image generation (optional free tier)
HUGGINGFACE_TOKEN=hf_your_hf_token_here

# Other runtime config
NEXT_PUBLIC_API_URL=http://localhost:8000

# -------------------- Ollama (local fallback) --------------------
# Install ollama (optional) and pull a local model for offline fallback:
#   curl -fsSL https://ollama.com/install.sh | sh
#   ollama pull llama3
# Ollama runs on http://localhost:11434 by default and requires no env vars.

# -------------------- Quick Gemini test (use your key to verify) --------------------
# curl "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=YOUR_KEY_A" \
#   -H 'Content-Type: application/json' \
#   -d '{"contents":[{"parts":[{"text":"Say hello"}]}]}'
