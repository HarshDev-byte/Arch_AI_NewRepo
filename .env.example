# .env.example — copy to .env and fill in

# Anthropic (get free at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (get free at console.groq.com — blazing fast)
GROQ_API_KEY=gsk_...

# Hugging Face (get FREE at huggingface.co/settings/tokens — no credit card)
# Used for AI mood board image generation (Stable Diffusion XL)
HF_API_KEY=hf_...

# Supabase Storage bucket name (default: archai-models)
SUPABASE_STORAGE_BUCKET=archai-models

# Mapbox (get free at mapbox.com)
MAPBOX_TOKEN=pk.eyJ1...

# Supabase (get free at supabase.com)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard  # Settings → API → JWT Secret
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres


# Upstash Redis (get free at upstash.com)
REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6379

# NREL API (get free at developer.nrel.gov)
NREL_API_KEY=your_key_here

# App config
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=${MAPBOX_TOKEN}
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Blender path (local 3D generation)
BLENDER_PATH=/usr/bin/blender

# Generation config
MAX_DESIGN_VARIANTS=5
EVOLUTION_GENERATIONS=3
ENABLE_VR=true
